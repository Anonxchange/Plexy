{
  "rewrites": [
    {
      "source": "/",
      "destination": "/support",
      "has": [
        {
          "type": "host",
          "value": "help.pexly.app"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/signin",
      "has": [
        {
          "type": "host",
          "value": "auth.pexly.app"
        }
      ]
    },
    {
      "source": "/shop/product/:handle",
      "destination": "https://YOUR_PROJECT_REF.supabase.co/functions/v1/prerender?path=/shop/product/:handle"
    },
    {
      "source": "/shop",
      "destination": "https://YOUR_PROJECT_REF.supabase.co/functions/v1/prerender?path=/shop"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.html|)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
