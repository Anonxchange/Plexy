{
  "redirects": [
    {
      "source": "/",
      "destination": "https://www.pexly.app/support",
      "has": [{ "type": "host", "value": "help.pexly.app" }],
      "permanent": false
    },
    {
      "source": "/",
      "destination": "https://www.pexly.app/signin",
      "has": [{ "type": "host", "value": "auth.pexly.app" }],
      "permanent": false
    },
    {
      "source": "/",
      "destination": "https://www.pexly.app/shop",
      "has": [{ "type": "host", "value": "shop.pexly.app" }],
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/cart/:path*",
      "destination": "https://qm0yih-vd.myshopify.com/cart/:path*",
      "has": [{ "type": "host", "value": "shop.pexly.app" }]
    },
    {
      "source": "/checkouts/:path*",
      "destination": "https://qm0yih-vd.myshopify.com/checkouts/:path*",
      "has": [{ "type": "host", "value": "shop.pexly.app" }]
    },
    {
      "source": "/payments/:path*",
      "destination": "https://qm0yih-vd.myshopify.com/payments/:path*",
      "has": [{ "type": "host", "value": "shop.pexly.app" }]
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.html|)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
